APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

WORKER_API_BASE_URL=http://localhost
WORKER_API_TIMEOUT=30
WORKER_API_CONNECT_TIMEOUT=10
WORKER_API_TOKEN_PATH=api/tokens/create
WORKER_API_EMAIL=admin@example.com
WORKER_API_PASSWORD=password
WORKER_API_TOKEN_NAME=worker
WORKER_API_ABILITIES=["*"]
WORKER_API_CLAIM_PATH=api/tasks/claim
WORKER_API_HEARTBEAT_PATH_TEMPLATE=api/tasks/%d/heartbeat
WORKER_API_FINISH_PATH_TEMPLATE=api/tasks/%d/finish
# Se WORKER_API_BASE_URL já incluir o prefixo /api (ex.: http://servidor:8080/api), use paths sem "api/":
# WORKER_API_TOKEN_PATH=tokens/create
# WORKER_API_CLAIM_PATH=tasks/claim
# WORKER_API_HEARTBEAT_PATH_TEMPLATE=tasks/%d/heartbeat
# WORKER_API_FINISH_PATH_TEMPLATE=tasks/%d/finish
WORKER_ID=worker-1
WORKER_POLLING_INTERVAL=30
WORKER_HEARTBEAT_INTERVAL=10
WORKER_MAX_ATTEMPTS_PER_EXECUTION=5
WORKER_PUBLICATION_ENABLED=true
WORKER_PUBLICATION_GIT_USER_NAME="Tasks Automation Worker"
WORKER_PUBLICATION_GIT_USER_EMAIL=worker@example.com
WORKER_PUBLICATION_REMOTE_NAME=origin
WORKER_CODEX_BINARY=codex
WORKER_CODEX_SANDBOX=danger-full-access
WORKER_PROCESS_TIMEOUT=3600
WORKER_CLEANUP_WORKSPACE=true
WORKER_CLEANUP_WORKSPACE_ON_SUCCESS=true
WORKER_CLEANUP_WORKSPACE_ON_FAILURE=false
NOTIFICATIONS_ENABLED=true
EVOLUTION_WHATSAPP_ENABLED=false
EVOLUTION_API_BASE_URL=http://localhost:8080
EVOLUTION_INSTANCE_NAME=worker-instance
EVOLUTION_DESTINATION_NUMBER=5511999999999
EVOLUTION_API_TIMEOUT=10
EVOLUTION_API_CONNECT_TIMEOUT=5
